# General Settings
APP_NAME="Pradeepa Info Tech API"
DEBUG=True
API_V1_STR="/api"

# JWT Security
SECRET_KEY="YOUR_SUPER_SECRET_JWT_KEY_MIN_32_CHARACTERS"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database Connection (MySQL)
# Local setup example:
DATABASE_URL="mysql+pymysql://root:password@localhost:3306/pradeepadb"
# Production setup example:
# DATABASE_URL="mysql+pymysql://user:password@railway-host:port/database"

# Email Configuration (SMTP)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-email@gmail.com"
SMTP_PASSWORD="your-app-password"
SMTP_FROM="info@pradeepainfotech.com"
SMTP_FROM_NAME="Pradeepa Info Tech"

# Cloudinary Credentials (Image Upload)
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# Razorpay credentials (Online Payments)
RAZORPAY_KEY_ID="rzp_test_xxxxxx"
RAZORPAY_KEY_SECRET="your-razorpay-secret"

# AI Chatbot Configuration
GEMINI_API_KEY="your-google-gemini-api-key"

# Backups folder path
BACKUP_DIR="c:\\Downloads\\own\\backups"

# Default Admin Seed details (for first-time login creation)
DEFAULT_ADMIN_EMAIL="admin@pradeepainfotech.com"
DEFAULT_ADMIN_PASSWORD="AdminSecurePassword123!"
